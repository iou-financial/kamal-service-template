KAMAL_REGISTRY_PASSWORD=$(aws secretsmanager get-secret-value --secret-id "nucleus/staging/KAMAL_REGISTRY_PASSWORD" --query SecretString --output text --region us-east-1)
SECRET_KEY_BASE=$(aws secretsmanager get-secret-value --secret-id "__SERVICE__/staging/SECRET_KEY_BASE" --query SecretString --output text --region us-east-1)
ORIGIN_CERTIFICATE_PEM=$(aws secretsmanager get-secret-value --secret-id "kamal/staging/origin-cert" --query SecretString --output text --region us-east-1)
ORIGIN_PRIVATE_KEY_PEM=$(aws secretsmanager get-secret-value --secret-id "kamal/staging/origin-key" --query SecretString --output text --region us-east-1)
